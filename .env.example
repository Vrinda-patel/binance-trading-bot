# =============================================================================
# Binance Futures Testnet - API Credentials
# =============================================================================
# 1. Register at: https://testnet.binancefuture.com
# 2. Generate API Key and Secret from the testnet dashboard.
# 3. Copy this file to .env and fill in your credentials:
#       cp .env.example .env
#
# WARNING: Never commit your .env file to version control.
# =============================================================================

BINANCE_TESTNET_API_KEY=your_api_key_here
BINANCE_TESTNET_API_SECRET=your_api_secret_here

# =============================================================================
# Optional Configuration
# =============================================================================
BINANCE_TESTNET_BASE_URL=https://testnet.binancefuture.com
REQUEST_TIMEOUT=10
MAX_RETRIES=3
LOG_LEVEL=INFO
